# Copy this file to .env and fill in your own values.
# .env is git-ignored and must never be committed.

# --- LLM (required) ---
# LLMod.ai API key for this group (create it in the LLMod.ai platform).
LLMOD_API_KEY=your-llmod-api-key-here
# OpenAI-compatible base URL for LLMod.ai.
LLMOD_BASE_URL=https://api.llmod.ai/v1
# Model name to use.
LLMOD_MODEL=gpt-4o-mini

# --- Tools (optional) ---
# If unset, the tool falls back to a built-in structured mock.
# Tavily powers search_tool and reviews_tool (https://tavily.com).
TAVILY_API_KEY=
# Geoapify powers maps_tool POI lookups (https://geoapify.com).
GEOAPIFY_API_KEY=
